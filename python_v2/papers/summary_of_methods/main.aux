\newlabel{tab:Ndrift}{{V}{7}{$N$-sensitivity at $\eref = 0.08$ for selected $q$ values. Peak drift (boldface) grows from $\Delta \numes = 0.010$ across $N \in \{32\text {--}72\}$ to $\Delta \numes = 0.046$ across $N \in \{32\text {--}240\}$}{table.5}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {C}Calibration inversion: $\nu _{\rm  target} \to q$}{7}{section*.30}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textbf  {Top ($N$-sensitivity):} $\nu _{\mathrm  {meas}}(q)$ at $\varepsilon _{\mathrm  {ref}}= 0.08$ for $N \in \{32, 48, 72, 120, 240\}$. The calibration curve shifts systematically toward lower $\nu _{\mathrm  {meas}}$ at fixed $q$ as $N$ increases; the total drift at $q = 1$ is $\Delta \nu _{\mathrm  {meas}}= 0.046$ from $N = 32$ to $N = 240$. \textbf  {Bottom ($\varepsilon _{\mathrm  {ref}}$-sensitivity):} $\nu _{\mathrm  {meas}}(q)$ at $N = 72$ for $\varepsilon _{\mathrm  {ref}}\in \{0.04, 0.06, 0.08, 0.10, 0.12\}$ (bottom to top). Max drift $= 0.045$ (large $q$); the highlighted curve $\varepsilon _{\mathrm  {ref}}= 0.08$ is the working reference. }}{8}{figure.5}\protected@file@percent }
\newlabel{fig:Nsensitivity}{{5}{8}{\textbf {Top ($N$-sensitivity):} $\numes (q)$ at $\eref = 0.08$ for $N \in \{32, 48, 72, 120, 240\}$. The calibration curve shifts systematically toward lower $\numes $ at fixed $q$ as $N$ increases; the total drift at $q = 1$ is $\Delta \numes = 0.046$ from $N = 32$ to $N = 240$. \textbf {Bottom ($\eref $-sensitivity):} $\numes (q)$ at $N = 72$ for $\eref \in \{0.04, 0.06, 0.08, 0.10, 0.12\}$ (bottom to top). Max drift $= 0.045$ (large $q$); the highlighted curve $\eref = 0.08$ is the working reference}{figure.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces $N$-drift $\Delta \nu _{\mathrm  {meas}}= \qopname  \relax m{max}_N\nu _{\mathrm  {meas}}- \qopname  \relax m{min}_N\nu _{\mathrm  {meas}}$ vs.\ $q$ at $\varepsilon _{\mathrm  {ref}}= 0.08$, across $N \in \{32, 48, 72, 120, 240\}$. The drift peaks near $q \approx 1$ and exceeds 0.04 across the mid-range squishiness axis, necessitating resolution-matched calibration at the production tier $N = 240$. }}{8}{figure.6}\protected@file@percent }
\newlabel{fig:Ndrift}{{6}{8}{$N$-drift $\Delta \numes = \max _N\numes - \min _N\numes $ vs.\ $q$ at $\eref = 0.08$, across $N \in \{32, 48, 72, 120, 240\}$. The drift peaks near $q \approx 1$ and exceeds 0.04 across the mid-range squishiness axis, necessitating resolution-matched calibration at the production tier $N = 240$}{figure.6}{}}
