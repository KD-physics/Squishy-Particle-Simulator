\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {Top:} Squishiness axis at fixed $b = 0.2$: $\nu _{\mathrm  {meas}}$ (filled circles, left axis) and $\Delta A$ (open squares, right axis) vs.\ $q$ at $\varepsilon _{\mathrm  {ref}}= 0.08$. The vertical dashed line marks the midpoint $q \cdot b = 1$ ($q = 5$). \textbf  {Bottom:} Shape collapse. Centered perimeter outlines at maximum strain ($\varepsilon _p\approx 0.12$) overlaid for $q \in \{0.05, 0.5, 1, 5, 20, 50\}$ (blue to red with increasing $q$). At fixed $\Delta A$, all outlines lie on a single curve; the visible differences arise entirely from different $\Delta A$ values. See Movie\nobreakspace  {}S1 for the animated version. }}{7}{figure.3}\protected@file@percent }
\newlabel{fig:sweep_and_shapes}{{3}{7}{\textbf {Top:} Squishiness axis at fixed $b = 0.2$: $\numes $ (filled circles, left axis) and $\dA $ (open squares, right axis) vs.\ $q$ at $\eref = 0.08$. The vertical dashed line marks the midpoint $q \cdot b = 1$ ($q = 5$). \textbf {Bottom:} Shape collapse. Centered perimeter outlines at maximum strain ($\ep \approx 0.12$) overlaid for $q \in \{0.05, 0.5, 1, 5, 20, 50\}$ (blue to red with increasing $q$). At fixed $\dA $, all outlines lie on a single curve; the visible differences arise entirely from different $\dA $ values. See Movie~S1 for the animated version}{figure.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Trajectory in the $(\Delta A, \nu _{\mathrm  {meas}})$ plane as $q$ varies from 0.05 to 50 at $b = 0.2$, $\varepsilon _{\mathrm  {ref}}= 0.08$, $N = 48$. The monotone curve demonstrates the one-to-one relationship between area loss and Poisson ratio at fixed $b$. Selected $q$ values are labeled; the midpoint $q \cdot b = 1$ is starred. }}{7}{figure.4}\protected@file@percent }
\newlabel{fig:dA_nu_trajectory}{{4}{7}{Trajectory in the $(\dA , \numes )$ plane as $q$ varies from 0.05 to 50 at $b = 0.2$, $\eref = 0.08$, $N = 48$. The monotone curve demonstrates the one-to-one relationship between area loss and Poisson ratio at fixed $b$. Selected $q$ values are labeled; the midpoint $q \cdot b = 1$ is starred}{figure.4}{}}
