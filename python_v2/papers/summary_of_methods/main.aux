\@writefile{lof}{\contentsline {figure}{\numberline {11}{\ignorespaces Centre-of-mass trajectories for all four Bond numbers ($N = 120$, $\kappa = 0.02$, $\alpha _{\rm  damp} = 5$). Curves are coloured by $\mathrm  {Bo}$ (light blue to dark red, increasing). The dashed black line is the analytic free-fall parabola $y_0 - \frac  {1}{2}g t^2$ for $\mathrm  {Bo} = 0.10$; the dotted brown line marks the resting height $\approx R_0$. Post-impact chattering and settling are clearly visible for larger $\mathrm  {Bo}$. Agreement with ballistic free-fall is within $2 \times 10^{-4}$ of the fall height in all cases. Movie\nobreakspace  {}S11 shows the full trajectory at $\mathrm  {Bo} = 0.10$.}}{14}{figure.11}\protected@file@percent }
\newlabel{fig:emulsion_fall_traj}{{11}{14}{Centre-of-mass trajectories for all four Bond numbers ($N = 120$, $\kappa = 0.02$, $\alpha _{\rm damp} = 5$). Curves are coloured by $\mathrm {Bo}$ (light blue to dark red, increasing). The dashed black line is the analytic free-fall parabola $y_0 - \frac {1}{2}g t^2$ for $\mathrm {Bo} = 0.10$; the dotted brown line marks the resting height $\approx R_0$. Post-impact chattering and settling are clearly visible for larger $\mathrm {Bo}$. Agreement with ballistic free-fall is within $2 \times 10^{-4}$ of the fall height in all cases. Movie~S11 shows the full trajectory at $\mathrm {Bo} = 0.10$}{figure.11}{}}
\citation{Pozrikidis1992,KimKarrila1991}
\citation{Ohnesorge1936}
\citation{EggersVillermaux2008}
\@writefile{lof}{\contentsline {figure}{\numberline {12}{\ignorespaces Final resting sag states at $\mathrm  {Bo} \in \{0.01, 0.05, 0.10\}$ (left to right). Each panel shows the droplet perimeter (outer surface contour including contact radius $r_c$) at rest on the floor (brown line). Sag $(R_{\rm  top} - R_{\rm  bot})/R_0$ and area change $\Delta A$ are annotated. All panels share the same spatial scale. The oblate deformation grows visibly with $\mathrm  {Bo}$, while $\Delta A < 0.1\%$ confirms that the surface-tension model enforces near-perfect area conservation throughout.}}{15}{figure.12}\protected@file@percent }
\newlabel{fig:emulsion_fall_sag}{{12}{15}{Final resting sag states at $\mathrm {Bo} \in \{0.01, 0.05, 0.10\}$ (left to right). Each panel shows the droplet perimeter (outer surface contour including contact radius $r_c$) at rest on the floor (brown line). Sag $(R_{\rm top} - R_{\rm bot})/R_0$ and area change $\Delta A$ are annotated. All panels share the same spatial scale. The oblate deformation grows visibly with $\mathrm {Bo}$, while $\Delta A < 0.1\%$ confirms that the surface-tension model enforces near-perfect area conservation throughout}{figure.12}{}}
